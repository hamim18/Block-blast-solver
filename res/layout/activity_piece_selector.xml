<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#11111B">

    <!-- Header info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#1E1E2E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tap piece untuk memilih. Tap lagi untuk batal."
            android:textColor="#6C7086"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvSelectedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Terpilih: 0 / 3"
            android:textColor="#89B4FA"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Grid piece -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPieces"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp"/>

    <!-- Tombol konfirmasi -->
    <Button
        android:id="@+id/btnConfirmPieces"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="12dp"
        android:text="✓ Konfirmasi (0/3)"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#89B4FA"
        android:textColor="#11111B"
        android:enabled="false"/>

</LinearLayout>
