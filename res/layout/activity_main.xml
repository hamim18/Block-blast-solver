<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#11111B"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Block Blast Solver"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#CDD6F4"
        android:gravity="center"
        android:paddingBottom="2dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap / drag untuk isi sel. Pilih piece lalu geser jari untuk preview."
        android:textSize="11sp"
        android:textColor="#6C7086"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <com.blockblast.solver.GridView
        android:id="@+id/gridView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp"/>

    <!-- Baris tombol utama -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Clear"
            android:textSize="11sp"
            android:backgroundTint="#313244"
            android:textColor="#CDD6F4"
            android:layout_marginEnd="3dp"/>

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="↩ Undo"
            android:textSize="11sp"
            android:backgroundTint="#45475A"
            android:textColor="#FAB387"
            android:layout_marginEnd="3dp"/>

        <Button
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="📷 Scan"
            android:textSize="11sp"
            android:backgroundTint="#313244"
            android:textColor="#A6E3A1"
            android:layout_marginEnd="3dp"/>

        <Button
            android:id="@+id/btnAddPiece"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="+ Piece"
            android:textSize="11sp"
            android:backgroundTint="#45475A"
            android:textColor="#CDD6F4"
            android:layout_marginEnd="3dp"/>

        <Button
            android:id="@+id/btnSolve"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Solve"
            android:textSize="11sp"
            android:backgroundTint="#89B4FA"
            android:textColor="#11111B"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Piece terpilih -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvPieceCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pieces: 0/3"
            android:textColor="#6C7086"
            android:textSize="12sp"
            android:paddingEnd="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSelectedPieces"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"/>
    </LinearLayout>

</LinearLayout>
